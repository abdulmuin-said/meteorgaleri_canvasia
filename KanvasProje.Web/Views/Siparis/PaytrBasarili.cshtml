@{
    ViewData["Title"] = "Ödeme Başarılı";
    var siparisNo = ViewBag.SiparisNo as string;
    var siparisId = ViewBag.SiparisId is int id ? id : 0;
    bool odemeBekliyor = ViewBag.OdemeBekliyor is bool bekliyor && bekliyor;
}

<div class="container mx-auto px-4 py-16 md:py-24">
    <div class="max-w-xl mx-auto text-center">
        @if (odemeBekliyor)
        {
            <!-- Ödeme henüz onaylanmadı -->
            <div class="w-20 h-20 bg-[#fcf9f3] border-2 border-[#b58735] rounded-full flex items-center justify-center mx-auto mb-8">
                <i class="fas fa-clock text-4xl text-[#b58735]"></i>
            </div>
            <h1 class="font-serif text-3xl md:text-5xl text-[#313511] mb-4">Ödeme İşleminiz Alındı</h1>
            <p class="text-[#47473d] mb-8 max-w-md mx-auto leading-relaxed">
                Ödeme işleminiz başarıyla başlatıldı. Siparişiniz, ödemeniz onaylandıktan sonra hazırlanmaya başlayacaktır.
                Onay süreci genellikle birkaç dakika içinde tamamlanır.
            </p>
        }
        else
        {
            <!-- Ödeme onaylandı -->
            <div class="w-20 h-20 bg-green-50 border-2 border-green-500 rounded-full flex items-center justify-center mx-auto mb-8">
                <i class="fas fa-check text-4xl text-green-600"></i>
            </div>
            <h1 class="font-serif text-3xl md:text-5xl text-[#313511] mb-4">Ödemeniz Onaylandı!</h1>
            <p class="text-[#47473d] mb-4 max-w-md mx-auto leading-relaxed">
                Siparişiniz başarıyla alındı ve ödemeniz onaylandı. Siparişiniz kısa süre içinde hazırlanmaya başlayacak.
            </p>
        }

        <div class="bg-white border border-[#e5e2dc] rounded-lg p-6 mb-8">
            <div class="text-xs uppercase tracking-widest text-[#47473d] mb-2">Sipariş Numaranız</div>
            <div class="text-2xl font-bold text-[#313511] tracking-tight">@siparisNo</div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/Profil/Siparislerim"
               class="inline-flex items-center justify-center gap-2 bg-[#313511] text-white text-sm font-medium tracking-widest uppercase px-8 py-4 rounded hover:bg-[#1c2001] transition-colors">
                <i class="fas fa-box"></i> Siparişlerim
            </a>
            <a href="/"
               class="inline-flex items-center justify-center gap-2 border border-[#e5e2dc] text-[#313511] text-sm font-medium tracking-widest uppercase px-8 py-4 rounded hover:bg-[#fcf9f3] transition-colors">
                <i class="fas fa-home"></i> Ana Sayfa
            </a>
        </div>

        @if (odemeBekliyor)
        {
            <div class="mt-8 bg-[#fcf9f3] border border-[#e5e2dc] rounded-lg p-5 text-left">
                <p class="text-sm text-[#47473d] flex items-start gap-3">
                    <i class="fas fa-info-circle text-[#b58735] mt-0.5"></i>
                    <span>
                        Ödemeniz bankanız tarafından onaylandı ancak henüz kesinleşmedi.
                        Sayfayı yenileyerek güncel durumu kontrol edebilirsiniz.
                        Kesinleşmeyen ödemeler <strong>24 saat</strong> içinde otomatik olarak iptal edilir.
                    </span>
                </p>
            </div>
        }

        <!-- Sipariş Detayı -->
        @if (siparisId > 0)
        {
            <div class="mt-6">
                <a href="/Profil/SiparisDetay/@siparisId"
                   class="text-sm text-[#b58735] hover:text-[#313511] transition-colors underline">
                    <i class="fas fa-arrow-right mr-1"></i> Sipariş Detayını Görüntüle
                </a>
            </div>
        }
    </div>
</div>
