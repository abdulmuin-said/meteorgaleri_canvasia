@{
    ViewData["Title"] = "PayTR ile Güvenli Ödeme";
    var token = ViewBag.PaytrToken as string;
    var siparisNo = ViewBag.SiparisNo as string;
    var toplamTutar = ViewBag.ToplamTutar is decimal t ? t : 0m;
    var hata = ViewBag.Hata as string;
}

<!-- Breadcrumb -->
<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-4">
    <div class="container mx-auto px-4 flex items-center justify-center gap-4 text-xs tracking-widest uppercase">
        <a href="/Sepet" class="text-[#47473d] hover:text-[#313511] transition-colors flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-[#e5e2dc] text-[#47473d] flex items-center justify-center font-bold">1</span> Sepet
        </a>
        <span class="text-[#e5e2dc]">/</span>
        <a href="/Siparis/Odeme" class="text-[#47473d] hover:text-[#313511] transition-colors flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-[#e5e2dc] text-[#47473d] flex items-center justify-center font-bold">2</span> Teslimat
        </a>
        <span class="text-[#e5e2dc]">/</span>
        <span class="text-[#313511] font-bold flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-[#313511] text-white flex items-center justify-center font-bold">3</span> Ödeme
        </span>
    </div>
</div>

<div class="container mx-auto px-4 py-12 md:py-16">
    <div class="text-center mb-12">
        <h1 class="font-serif text-3xl md:text-5xl text-[#313511] mb-4">Güvenli Ödeme</h1>
        <p class="text-sm text-[#47473d] max-w-2xl mx-auto">
            Siparişiniz oluşturuldu. Aşağıdaki güvenli ödeme formunu kullanarak ödemenizi tamamlayın.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(hata))
    {
        <div class="max-w-2xl mx-auto mb-8 rounded-lg border border-red-200 bg-red-50 px-6 py-5 text-sm text-red-700">
            <div class="font-semibold mb-1">Ödeme başlatılamadı</div>
            <p>@hata</p>
            <a href="/Siparis/Odeme" class="inline-block mt-3 text-[#313511] underline font-medium">Tekrar dene</a>
        </div>
    }
    else if (!string.IsNullOrEmpty(token))
    {
        <!-- Sipariş Özeti -->
        <div class="max-w-3xl mx-auto mb-8 bg-white border border-[#e5e2dc] rounded-lg p-6">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                    <span class="text-xs uppercase tracking-widest text-[#47473d]">Sipariş No</span>
                    <div class="text-lg font-bold text-[#313511]">@siparisNo</div>
                </div>
                <div class="text-right">
                    <span class="text-xs uppercase tracking-widest text-[#47473d]">Toplam Tutar</span>
                    <div class="text-2xl font-bold text-[#313511]">@toplamTutar.ToString("N2") TL</div>
                </div>
            </div>
        </div>

        <!-- PayTR Güvenli Ödeme Iframe -->
        <div class="max-w-3xl mx-auto bg-white border border-[#e5e2dc] rounded-lg overflow-hidden">
            <div class="bg-[#313511] text-white text-xs tracking-widest uppercase px-6 py-3 flex items-center gap-3">
                <i class="fas fa-lock"></i>
                <span>256-Bit SSL Güvenli Ödeme</span>
                <span class="ml-auto flex items-center gap-2">
                    <i class="fab fa-cc-visa text-lg"></i>
                    <i class="fab fa-cc-mastercard text-lg"></i>
                    <i class="fab fa-cc-amex text-lg"></i>
                </span>
            </div>
            <div class="p-4 md:p-8">
                @* iframeResizer: PayTR'ın ödeme iframe'inin otomatik boyutlanması için gereklidir *@
                <script src="https://www.paytr.com/js/iframeResizer.min.js"></script>
                <iframe src="https://www.paytr.com/odeme/guvenli/@token"
                        id="paytriframe"
                        frameborder="0"
                        scrolling="no"
                        style="width: 100%; min-height: 640px;"
                        class="paytr-iframe">
                </iframe>
                <script>iFrameResize({}, '#paytriframe');</script>

                <div class="mt-6 pt-4 border-t border-[#e5e2dc] text-center">
                    <p class="text-xs text-[#47473d]">
                        <i class="fas fa-shield-alt text-[#b58735] mr-1"></i>
                        Ödemeniz PayTR tarafından 256-Bit SSL ile korunmaktadır.
                        Kart bilgileriniz mağazamızla paylaşılmaz.
                    </p>
                </div>
            </div>
        </div>

        <!-- İşlem Beklerken Uyarı -->
        <div class="max-w-3xl mx-auto mt-6 bg-[#fcf9f3] border border-[#e5e2dc] rounded-lg p-4 text-center">
            <p class="text-sm text-[#47473d]">
                <i class="fas fa-info-circle text-[#b58735] mr-1"></i>
                Ödeme işleminiz tamamlandıktan sonra yönlendirileceksiniz.
                Herhangi bir sorun olursa
                <a href="/Kurumsal/Iletisim" class="text-[#313511] underline font-medium">iletişime</a>
                geçebilirsiniz.
            </p>
        </div>
    }
    else
    {
        <div class="max-w-2xl mx-auto text-center py-12">
            <div class="animate-spin w-10 h-10 border-4 border-[#e5e2dc] border-t-[#313511] rounded-full mx-auto mb-6"></div>
            <p class="text-[#47473d]">Ödeme sayfası hazırlanıyor...</p>
            <meta http-equiv="refresh" content="3">
        </div>
    }
</div>

<style>
    .paytr-iframe {
        transition: opacity 0.3s ease;
    }
    .paytr-iframe.loading {
        opacity: 0.5;
    }
</style>

<script>
    // Iframe yüklenirken gösterge
    document.addEventListener('DOMContentLoaded', function() {
        var iframe = document.getElementById('paytriframe');
        if (iframe) {
            iframe.classList.add('loading');
            iframe.addEventListener('load', function() {
                this.classList.remove('loading');
            });
        }
    });
</script>
