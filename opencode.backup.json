{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "E:\\Projeler\\MeteorGaleri"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "provider": {
  "openrouter": {
    "options": {
      "baseURL": "https://openrouter.ai/api/v1"
    }
  }
},

"model": "openrouter/minimax/minimax-m2.5:free",
"small_model": "openrouter/minimax/minimax-m2.5:free",

    "postgresql-readonly": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:CANVASIA_AI_READER_DB_URL}"
      ],
      "enabled": true,
      "timeout": 10000
    },

    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chrome"
      ],
      "enabled": true,
      "timeout": 30000
    },

    "github": {
  "enabled": false
},

    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },

    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 10000
    },

    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-fetch-typescript"
      ],
      "enabled": true,
      "timeout": 10000
    },

    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true
    },

    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },

  "permission": {
    "edit": "ask",
    "bash": "ask",
    "lsp": "allow"
  },

  "lsp": {
    "csharp": {
      "command": "csharp-ls",
      "args": []
    }
  },

  "instructions": [
    "CLAUDE.md",
    "README.md"
  ]
}