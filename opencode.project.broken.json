{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "E:\\Projeler\\MeteorGaleri"
      ],
      "enabled": true,
      "timeout": 10000
    },

    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 10000
    }
  },

  "permission": {
    "edit": "ask",
    "bash": "ask",
    "lsp": "allow"
  },

  "lsp": {
    "csharp": {
      "command": "csharp-ls",
      "args": []
    }
  },

  "instructions": [
    "CLAUDE.md",
    "README.md"
  ]
}